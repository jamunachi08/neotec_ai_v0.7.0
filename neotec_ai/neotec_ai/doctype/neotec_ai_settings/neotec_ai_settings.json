{
  "doctype": "DocType",
  "name": "Neotec AI Settings",
  "module": "Neotec AI",
  "custom": 0,
  "istable": 0,
  "editable_grid": 1,
  "engine": "InnoDB",
  "track_changes": 1,
  "allow_import": 1,
  "quick_entry": 0,
  "sort_field": "modified",
  "sort_order": "DESC",
  "autoname": "prompt",
  "fields": [
    {
      "fieldname": "default_mode",
      "fieldtype": "Select",
      "label": "Default Mode",
      "options": "AI Chat\nBI / Reports\nDocument AI\nAutomate Work\nVoice",
      "reqd": 1
    },
    {
      "fieldname": "enable_document_ai",
      "fieldtype": "Check",
      "label": "Enable Document AI",
      "default": "1"
    },
    {
      "fieldname": "enable_bi_mode",
      "fieldtype": "Check",
      "label": "Enable BI Mode",
      "default": "1"
    },
    {
      "fieldname": "enable_voice",
      "fieldtype": "Check",
      "label": "Enable Voice",
      "default": "1"
    },
    {
      "fieldname": "allow_draft_actions",
      "fieldtype": "Check",
      "label": "Allow Draft Actions"
    },
    {
      "fieldname": "provider_name",
      "fieldtype": "Data",
      "label": "Provider Name"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "print": 1,
      "email": 1,
      "report": 1,
      "share": 1
    },
    {
      "role": "All",
      "read": 1
    }
  ],
  "issingle": 1
}