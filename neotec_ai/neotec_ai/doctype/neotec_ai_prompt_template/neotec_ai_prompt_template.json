{
  "doctype": "DocType",
  "name": "Neotec AI Prompt Template",
  "module": "Neotec AI",
  "custom": 0,
  "istable": 0,
  "editable_grid": 1,
  "engine": "InnoDB",
  "track_changes": 1,
  "allow_import": 1,
  "quick_entry": 0,
  "sort_field": "modified",
  "sort_order": "DESC",
  "autoname": "field:title",
  "fields": [
    {
      "fieldname": "title",
      "fieldtype": "Data",
      "label": "Title",
      "reqd": 1
    },
    {
      "fieldname": "prompt_text",
      "fieldtype": "Text Editor",
      "label": "Prompt Text",
      "reqd": 1
    },
    {
      "fieldname": "module_scope",
      "fieldtype": "Data",
      "label": "Module Scope"
    },
    {
      "fieldname": "prompt_type",
      "fieldtype": "Select",
      "label": "Prompt Type",
      "options": "Insight\nAction\nReport\nDashboard\nDocument AI"
    },
    {
      "fieldname": "is_system",
      "fieldtype": "Check",
      "label": "System Template",
      "default": "0"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "print": 1,
      "email": 1,
      "report": 1,
      "share": 1
    },
    {
      "role": "All",
      "read": 1
    }
  ]
}