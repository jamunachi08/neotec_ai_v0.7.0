{
  "doctype": "DocType",
  "name": "Neotec Ai Data Source",
  "module": "Neotec AI",
  "custom": 0,
  "istable": 0,
  "editable_grid": 1,
  "engine": "InnoDB",
  "track_changes": 1,
  "allow_import": 1,
  "quick_entry": 0,
  "sort_field": "modified",
  "sort_order": "DESC",
  "autoname": "field:source_name",
  "fields": [
    {
      "fieldname": "source_name",
      "fieldtype": "Data",
      "label": "Source Name",
      "reqd": 1
    },
    {
      "fieldname": "source_type",
      "fieldtype": "Select",
      "label": "Source Type",
      "options": "ERP Database\nMySQL\nPostgreSQL\nOracle\nSQL Server\nExcel / CSV\nSocial Connector"
    },
    {
      "fieldname": "connection_reference",
      "fieldtype": "Data",
      "label": "Connection Reference"
    },
    {
      "fieldname": "enabled",
      "fieldtype": "Check",
      "label": "Enabled",
      "default": "1"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "print": 1,
      "email": 1,
      "report": 1,
      "share": 1
    },
    {
      "role": "All",
      "read": 1
    }
  ]
}