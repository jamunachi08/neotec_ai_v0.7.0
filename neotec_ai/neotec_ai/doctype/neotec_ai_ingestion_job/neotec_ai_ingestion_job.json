{
  "doctype": "DocType",
  "name": "Neotec Ai Ingestion Job",
  "module": "Neotec AI",
  "custom": 0,
  "istable": 0,
  "editable_grid": 1,
  "engine": "InnoDB",
  "track_changes": 1,
  "allow_import": 1,
  "quick_entry": 0,
  "sort_field": "modified",
  "sort_order": "DESC",
  "autoname": "hash",
  "fields": [
    {
      "fieldname": "title",
      "fieldtype": "Data",
      "label": "Title",
      "reqd": 1
    },
    {
      "fieldname": "source_type",
      "fieldtype": "Select",
      "label": "Source Type",
      "options": "Image\nPDF\nExcel\nWord\nEmail\nSocial Media"
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Queued\nProcessing\nCompleted\nFailed",
      "default": "Queued"
    },
    {
      "fieldname": "payload_reference",
      "fieldtype": "Data",
      "label": "Payload Reference"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "print": 1,
      "email": 1,
      "report": 1,
      "share": 1
    },
    {
      "role": "All",
      "read": 1
    }
  ]
}